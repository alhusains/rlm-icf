# =============================================================================
# UHN ICF Pipeline — Unified Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All 4 extraction backends + evaluation use the same .env file.

# -----------------------------------------------------------------------------
# Azure OpenAI (powers RLM, Naive, Azure AI Search backends + eval judge)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------------
# Azure AI Search (for azure_ai_search backend)
# -----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-key
AZURE_SEARCH_INDEX=your-index-name
